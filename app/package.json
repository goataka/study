{
  "name": "quiz",
  "version": "2.0.0",
  "description": "子供向け学習アプリ",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit --project tsconfig.build.json && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "bddgen && playwright test",
    "test:e2e:ui": "bddgen && playwright test --ui",
    "pretest:e2e:vr": "bash scripts/setup-env.sh",
    "test:e2e:vr": "bddgen --config playwright.vr.config.ts && playwright test --config playwright.vr.config.ts",
    "pretest:e2e:vr:update": "bash scripts/setup-env.sh",
    "test:e2e:vr:update": "bddgen --config playwright.vr.config.ts && playwright test --config playwright.vr.config.ts --update-snapshots=all",
    "prepare": "cd .. && lefthook install"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.0.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.2",
    "lefthook": "^2.1.6",
    "playwright-bdd": "^8.5.0",
    "typescript": "^5.8.3",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "tesseract.js": "^7.0.0"
  }
}
