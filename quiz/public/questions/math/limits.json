    {
      "id": "lim-1",
      "question": "lim(n→∞) 1/n = ?",
      "choices": [
        "0",
        "1",
        "∞",
        "1/2"
      ],
      "correct": 0,
      "explanation": "nが無限大に近づくと、1/nは0に近づきます"
    },
    {
      "id": "lim-2",
      "question": "lim(n→∞) (2n+1)/n = ?",
      "choices": [
        "2",
        "1",
        "0",
        "∞"
      ],
      "correct": 0,
      "explanation": "分子分母をnで割ると、(2+1/n)/1。n→∞のとき1/n→0なので、極限は2"
    },
    {
      "id": "lim-3",
      "question": "lim(n→∞) (3n²+1)/(n²+2) = ?",
      "choices": [
        "3",
        "1",
        "2",
        "0"
      ],
      "correct": 0,
      "explanation": "分子分母をn²で割ると、(3+1/n²)/(1+2/n²)。n→∞で極限は3/1 = 3"
    },
    {
      "id": "lim-4",
      "question": "lim(n→∞) n/(n²+1) = ?",
      "choices": [
        "0",
        "1",
        "∞",
        "1/2"
      ],
      "correct": 0,
      "explanation": "分子分母をn²で割ると、(1/n)/(1+1/n²)。n→∞で極限は0/1 = 0"
    },
    {
      "id": "lim-5",
      "question": "lim(x→2) (x²-4)/(x-2) = ?",
      "choices": [
        "4",
        "2",
        "0",
        "∞"
      ],
      "correct": 0,
      "explanation": "因数分解: (x²-4)/(x-2) = (x+2)(x-2)/(x-2) = x+2。x→2で極限は4"
    },
    {
      "id": "lim-6",
      "question": "lim(x→0) sin(x)/x = ?",
      "choices": [
        "1",
        "0",
        "∞",
        "sin(0)"
      ],
      "correct": 0,
      "explanation": "これは重要な極限の公式。lim(x→0) sin(x)/x = 1"
    },
    {
      "id": "lim-7",
      "question": "lim(x→1) (x²-1)/(x-1) = ?",
      "choices": [
        "2",
        "1",
        "0",
        "∞"
      ],
      "correct": 0,
      "explanation": "因数分解: (x²-1)/(x-1) = (x+1)(x-1)/(x-1) = x+1。x→1で極限は2"
    },
    {
      "id": "lim-8",
      "question": "lim(x→∞) (2x+1)/(3x-1) = ?",
      "choices": [
        "2/3",
        "1",
        "3/2",
        "0"
      ],
      "correct": 0,
      "explanation": "分子分母をxで割ると、(2+1/x)/(3-1/x)。x→∞で極限は2/3"
    },
    {
      "id": "lim-9",
      "question": "lim(n→∞) (5n + 2)/n = ?",
      "choices": [
        "5",
        "2",
        "0",
        "∞"
      ],
      "correct": 0,
      "explanation": "(5n+2)/n = 5 + 2/n → 5 (n→∞)"
    },
    {
      "id": "lim-10",
      "question": "lim(x→3) (x² - 9)/(x - 3) = ?",
      "choices": [
